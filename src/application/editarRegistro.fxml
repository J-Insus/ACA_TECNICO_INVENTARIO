            </VBox>
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="20.0" prefWidth="1280.0">
         <children>
            <Label alignment="CENTER" contentDisplay="RIGHT" prefHeight="30.0" prefWidth="223.0" text="Observaciones" textFill="#093c5d">
