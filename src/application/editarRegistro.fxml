            <ComboBox fx:id="modTipoEquipo" prefHeight="42.0" prefWidth="237.0" promptText="Seleccione" style="-fx-background-color: #E6E3E3; -fx-background-radius: 15; -fx-padding: 5 15 5 15;" />
