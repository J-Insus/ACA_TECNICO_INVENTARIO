            <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" prefHeight="30.0" prefWidth="173.0" text="Marca / Modelo" textAlignment="RIGHT" textFill="#3b7597">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <TextField fx:id="modMarcaM" prefHeight="39.0" prefWidth="283.0" style="-fx-background-color: #E6E3E3; -fx-background-radius: 15; -fx-text-fill: #093C5D; -fx-padding: 10 15 10 15;">
               <font>
                  <Font size="18.0" />
               </font>
            </TextField>
            <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" prefHeight="30.0" prefWidth="173.0" text="Serial" textAlignment="RIGHT" textFill="#3b7597">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <TextField fx:id="modSerial" prefHeight="39.0" prefWidth="283.0" style="-fx-background-color: #E6E3E3; -fx-background-radius: 15; -fx-text-fill: #093C5D; -fx-padding: 10 15 10 15;">
               <font>
                  <Font size="18.0" />
               </font>
            </TextField>
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="72.0" prefWidth="1280.0" spacing="30.0">
