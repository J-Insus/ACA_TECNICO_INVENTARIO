                  <Font size="18.0" />
               </font>
            </TextField>
            <Label alignment="CENTER_RIGHT" prefWidth="110.0" text="Telefono" textAlignment="RIGHT" textFill="#3b7597">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <TextField fx:id="modTelefono" style="-fx-background-color: #E6E3E3; -fx-background-radius: 15; -fx-text-fill: #093C5D; -fx-padding: 10 15 10 15;">
               <font>
                  <Font size="18.0" />
               </font>
            </TextField>
         </children>
      </HBox>
      <HBox alignment="CENTER" layoutX="10.0" layoutY="396.0" prefHeight="140.0" prefWidth="1280.0" spacing="20.0" style="-fx-background-color: #E8E8E8;">
