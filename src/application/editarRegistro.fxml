<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="720.0" prefWidth="1280.0" spacing="35.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.EditarRegistroController">
   <children>
      <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="347.0" prefWidth="1280.0" style="-fx-background-color: #E8E8E8;" text="Editar Datos del Registro" textFill="#093c5d">
         <font>
            <Font name="System Bold" size="44.0" />
         </font>
      </Label>
      <HBox alignment="CENTER" prefHeight="0.0" prefWidth="1280.0" spacing="20.0">
         <children>
            <Label alignment="TOP_RIGHT" prefWidth="110.0" text="Nombre" textAlignment="RIGHT" textFill="#3b7597">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <TextField fx:id="modNombreCliente" prefHeight="0.0" prefWidth="224.0" style="-fx-background-color: #E6E3E3; -fx-background-radius: 15; -fx-text-fill: #093C5D; -fx-padding: 10 15 10 15;">
               <font>
                  <Font size="18.0" />
               </font>
            </TextField>
            <Label alignment="CENTER_RIGHT" prefHeight="30.0" prefWidth="79.0" text="Cédula" textAlignment="RIGHT" textFill="#3b7597">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <TextField fx:id="modCedula" style="-fx-background-color: #E6E3E3; -fx-background-radius: 15; -fx-text-fill: #093C5D; -fx-padding: 10 15 10 15;">
