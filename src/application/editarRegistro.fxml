            <TextField fx:id="modObervaciones" prefHeight="39.0" prefWidth="246.0" promptText="Observaciones Físicas" style="-fx-background-color: #E6E3E3; -fx-background-radius: 15; -fx-text-fill: #093C5D; -fx-padding: 10 20 10 20;">
               <font>
