                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                     <toggleGroup>
                        <ToggleGroup fx:id="grupoPrioridad" />
                     </toggleGroup>
                  </RadioButton>
                  <RadioButton fx:id="modNo" mnemonicParsing="false" text="No" textFill="#093c5d">
                     <font>
                        <Font size="18.0" />
                     </font>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                     <toggleGroup>
                        <ToggleGroup fx:id="grupoPrioridad" />
                     </toggleGroup>
                  </RadioButton>
               </children>
            </HBox>
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="391.0" prefWidth="1280.0">
