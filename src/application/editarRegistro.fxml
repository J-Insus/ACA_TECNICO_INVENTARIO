            <VBox prefHeight="178.0" prefWidth="427.0">
               <children>
                  <Label alignment="CENTER" contentDisplay="RIGHT" prefHeight="30.0" prefWidth="600.0" text="Razón de Revisión" textFill="#093c5d">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <TextArea fx:id="modRevision" prefHeight="132.0" prefWidth="0.0" style="-fx-control-inner-background: #E6E3E3; -fx-border-radius: 15; -fx-border-color: transparent; -fx-text-fill: #093C5D; -fx-padding: 5; -fx-background-radius: 10;" />
