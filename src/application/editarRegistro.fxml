      <HBox alignment="CENTER" prefHeight="328.0" prefWidth="1280.0" style="-fx-background-color: #E8E8E8;">
         <children>
            <Button fx:id="btnIngresarSis" mnemonicParsing="false" onAction="#actualizarRegistro" prefHeight="60.0" prefWidth="189.0" style="-fx-background-color: #093C5D; -fx-background-radius: 35; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 12 45 12 45;" text="Guardar">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </Button>
         </children>
         <padding>
            <Insets left="850.0" />
         </padding>
      </HBox>
